<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===================================================================
         PERMISSIONS
         =================================================================== -->

    <!-- Internet — required for all API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Network state — lets Retrofit detect offline before making calls -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Location — required by Radar screen / LocationService -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Camera — required for QR code scanning (Phase 2) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- ===================================================================
         APPLICATION
         =================================================================== -->
    <application
        android:name=".KnowItAllApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KnowItAll"
        android:usesCleartextTraffic="true">
        <!--
            android:usesCleartextTraffic="true" is required for the development
            backend running over HTTP (http://192.168.0.107:8080).
            REMOVE THIS LINE before production — production must use HTTPS.
            Alternatively, add a network_security_config.xml that allows
            cleartext only for specific development IPs.
        -->

        <!-- Main entry point -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.KnowItAll"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===============================================================
             FILE PROVIDER — required for sharing PDF Skill Passports
             ===============================================================
             FileProvider converts a raw File path into a content:// URI
             that other apps (PDF viewers, email clients, Drive) can open
             without needing direct filesystem permissions.

             HOW IT WORKS:
               1. SkillPassportGenerator writes the PDF to
                  getExternalFilesDir("passports")
               2. VaultScreenEnhanced calls FileProvider.getUriForFile()
                  to get a content:// URI for that file
               3. An Intent with ACTION_VIEW + FLAG_GRANT_READ_URI_PERMISSION
                  opens the PDF in any installed viewer

             AUTHORITY RULE:
               The authority string MUST be "${applicationId}.fileprovider"
               exactly. It is referenced in VaultScreenEnhanced as:
               "${context.packageName}.fileprovider"
               Both must match or the URI will fail to resolve.

             PATH CONFIG:
               android:resource="@xml/file_paths" points to
               res/xml/file_paths.xml which maps directory names to real paths.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>