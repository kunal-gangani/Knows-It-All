  @NonNull
  protected Map<Class<?>, List<Class<?>>> getRequiredTypeConverters() {
    final HashMap<Class<?>, List<Class<?>>> _typeConvertersMap = new HashMap<Class<?>, List<Class<?>>>();
    _typeConvertersMap.put(UserDao.class, UserDao_Impl.getRequiredConverters());
    _typeConvertersMap.put(SkillDao.class, SkillDao_Impl.getRequiredConverters());
    _typeConvertersMap.put(SwapDao.class, SwapDao_Impl.getRequiredConverters());
    _typeConvertersMap.put(TrustLedgerDao.class, TrustLedgerDao_Impl.getRequiredConverters());
    return _typeConvertersMap;
  }

